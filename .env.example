# Copy to .env.local and fill in. All server-side only.
# Without a key the app still runs fully — it falls back to the deterministic
# rule-based reasoning layer.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# tsaaguur.mn civic-pulse API (real-time Facebook/news trends). Optional —
# without it the app uses a bundled sample. Endpoint must return JSON shaped
# like src/lib/social/sample.json.
TSAAGUUR_API_URL=
